<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TaskDetailsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tv1"
            android:layout_width="307dp"
            android:layout_height="0dp"
            android:layout_marginStart="41dp"
            android:layout_marginTop="90dp"
            android:layout_marginEnd="63dp"
            android:layout_marginBottom="43dp"
            android:text="Subject:"
            app:layout_constraintBottom_toTopOf="@+id/etSubStartTime"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/etSubTitle"
            android:layout_width="198dp"
            android:layout_height="0dp"
            android:layout_marginTop="89dp"
            android:layout_marginEnd="68dp"
            android:layout_marginBottom="43dp"
            android:ems="10"
            android:hint="Enter Subject's Title..."
            android:inputType="text"
            app:layout_constraintBottom_toTopOf="@+id/tv2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.97"
            app:layout_constraintStart_toEndOf="@+id/tv1"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginEnd="1dp"
            android:layout_marginBottom="508dp"
            android:text="Start Time:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/etSubTitle"
            app:layout_constraintStart_toStartOf="@+id/tv3"
            app:layout_constraintTop_toBottomOf="@+id/etSubTitle" />

        <EditText
            android:id="@+id/etSubStartTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="56dp"
            android:layout_marginBottom="38dp"
            android:ems="10"
            android:hint="Enter Start Time..."
            android:inputType="text"
            app:layout_constraintBottom_toTopOf="@+id/etSubEndTime"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv1" />

        <TextView
            android:id="@+id/tv3"
            android:layout_width="300dp"
            android:layout_height="51dp"
            android:layout_marginStart="41dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="418dp"
            android:text="End Time:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/etSubEndTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/etSubEndTime" />

        <EditText
            android:id="@+id/etSubEndTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="55dp"
            android:layout_marginBottom="424dp"
            android:ems="10"
            android:hint="Enter End Time..."
            android:inputType="text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/etSubStartTime"
            app:layout_constraintTop_toBottomOf="@+id/etSubStartTime" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>